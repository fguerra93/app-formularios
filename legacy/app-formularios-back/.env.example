# ============================================
# PrintUp Backend — Variables de Entorno
# Copia este archivo como .env y edita los valores
# ============================================

# --- Servidor ---
PORT=3000
HOST=0.0.0.0

# --- Nextcloud WebDAV ---
NEXTCLOUD_URL=https://tu-nextcloud.ejemplo.com
NEXTCLOUD_USER=printup-upload
NEXTCLOUD_PASSWORD=tu-contraseña-segura
NEXTCLOUD_FOLDER=/PrintUp/Pedidos_Nuevos

# --- Email (SMTP) ---
# Gmail: smtp.gmail.com / Puerto: 465 / Secure: true
# Para Gmail necesitas una "App Password" (no tu contraseña normal)
# Ver: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
NOTIFY_TO=guerrafelipe93@gmail.com
NOTIFY_FROM=PrintUp Formulario <tucorreo@gmail.com>

# --- CORS ---
# En producción: https://formulario.printup.cl
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# --- Límites ---
MAX_FILE_SIZE_MB=100
MAX_FILES=10

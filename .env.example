# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email provider)
RESEND_API_KEY=re_your_api_key

# Email notifications
NOTIFY_TO=guerrafelipe93@gmail.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=PrintUp Formulario

# Nextcloud (sync worker sube archivos via WebDAV)
NEXTCLOUD_URL=https://printup.internos
NEXTCLOUD_USER=bot-formularios
NEXTCLOUD_PASSWORD=your-app-password
NEXTCLOUD_FOLDER=/PrintUp/Pedidos_Nuevos
NEXTCLOUD_BROWSE_FOLDER=/Shared/PrintUp/Pedidos_Nuevos

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Auth Admin
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=printup-secret-change-in-production
